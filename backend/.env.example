DATABASE_URL=file:./dev.db

# AI provider for GET /ai/plan
OPENAI_API_KEY=
AI_PLAN_PROVIDER=stub
AI_PLAN_MODEL=gpt-5
AI_PLAN_TEMPERATURE=0
AI_PLAN_MAX_OUTPUT_TOKENS=2000
AI_INSIGHTS_PROVIDER=stub
AI_INSIGHTS_MODEL=gpt-5-mini
AI_INSIGHTS_MAX_OUTPUT_TOKENS=1200

# Optional: Redis-backed AI rate-limit store.
# When unset or empty, the backend uses an in-memory Map (single-process only).
# Example: redis://localhost:6379
REDIS_URL=
# Optional: when set to 1, Redis init failure becomes fatal for AI cache.
# NODE_ENV=production also enforces strict Redis mode for AI cache.
AI_CACHE_STRICT_REDIS=0